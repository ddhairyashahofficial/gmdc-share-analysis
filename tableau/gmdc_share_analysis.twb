      <aliases enabled='yes' />
      <column caption='50D_MA' datatype='real' name='[20D_MA (copy)_673006733358190593]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Close]), -49, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Daily Return %' datatype='real' name='[Calculation_1217097863681134592]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Close]-[Open])/[Open]*100' />
      </column>
      <column caption='Price change type' datatype='string' name='[Calculation_1217097863681482753]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Close] &gt; [Open]&#13;&#10;    THEN &quot;Gain&quot;&#13;&#10;ELSE &quot;Loss&quot; &#13;&#10;END' />
      </column>
      <column caption='Annual Volatility' datatype='real' name='[Calculation_1217097863682580483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([Calculation_1217097863681134592]) * SQRT(252)' />
      </column>
      <column caption='Gap(close and open)' datatype='real' name='[Calculation_1217097863707959300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Close])-AVG([Open]))*-1' />
      </column>
      <column caption='Gap(high and low)' datatype='real' name='[Calculation_1217097863708430342]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([High])-AVG([Low]))*-1' />
      </column>
      <column caption='20D_MA' datatype='real' name='[Calculation_673006733357867008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Close]), -19, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='None' datatype='integer' name='[Close (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='1' formula='[Close]' peg='0' size='14.9' />
      </column>
